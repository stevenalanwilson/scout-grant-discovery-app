generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LegalStructure {
  UNINCORPORATED_ASSOCIATION
  CHARITABLE_INCORPORATED_ORGANISATION
  CHARITABLE_COMPANY_LIMITED_BY_GUARANTEE
  COMMUNITY_INTEREST_COMPANY
  OTHER
}

model Group {
  // ── existing fields — unchanged ──────────────────────────────────────
  id                        String    @id @default(cuid())
  name                      String
  membershipNumber          String
  charityNumber             String?
  postcode                  String
  region                    String?
  sections                  String[]
  membershipCount           Int
  fundingPurposes           String[]
  additionalContext         String?
  deprivationFlag           Boolean?
  deprivationOverride       Boolean?
  deprivationOverrideReason String?
  ruralFlag                 Boolean?
  ruralOverride             Boolean?
  ruralOverrideReason       String?

  // ── Category 1: Identity & registration ─────────────────────────────
  legalStructure                  LegalStructure?
  registeredWithCharityCommission Boolean?
  yearEstablished                 Int?
  constitutionInPlace             Boolean?
  bankAccountInGroupName          Boolean?

  // ── Category 2: Location & community ────────────────────────────────
  imdDecile                 Int?
  localAuthority            String?
  parliamentaryConstituency String?
  communityServed           String?

  // ── Category 3: Financial profile ───────────────────────────────────
  annualIncome                  Int?
  annualExpenditure             Int?
  financialYearEnd              String?
  hasCurrentAccounts            Boolean?
  currentGrantsHeld             Int?
  largestSingleFunderPercentage Int?

  // ── Category 4: Governance & compliance ─────────────────────────────
  safeguardingPolicyInPlace                Boolean?
  safeguardingPolicyReviewedWithin12Months Boolean?
  equalitiesPolicyInPlace                  Boolean?
  publicLiabilityInsurance                 Boolean?
  numberOfTrustees                         Int?
  trusteesAreUnrelated                     Boolean?
  hasOutstandingMonitoringReports          Boolean?

  // ── Category 5: Programme & beneficiary ─────────────────────────────
  volunteerCount               Int?
  percentageFreeSchoolMeals    Int?
  percentageDisabledOrSEND     Int?
  specificProjectDescription   String?
  estimatedProjectCost         Int?
  staffOrPaidWorkers           Boolean?

  // ── relations — unchanged ────────────────────────────────────────────
  agentRuns          AgentRun[]
  grants             Grant[]
  eligibilityResults EligibilityResult[]
  shortlistItems     ShortlistItem[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model AgentRun {
  id               String         @id @default(cuid())
  groupId          String
  group            Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  startedAt        DateTime       @default(now())
  completedAt      DateTime?
  status           AgentRunStatus
  grantsFoundCount Int            @default(0)
  grantsNewCount   Int            @default(0)
  errorMessage     String?
  nextRunAt        DateTime?
  progressLog      Json?
  createdAt        DateTime       @default(now())
}

enum AgentRunStatus {
  RUNNING
  SUCCESS
  FAILED
  RETRYING
}

model Grant {
  id                  String              @id @default(cuid())
  groupId             String
  group               Group               @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sourceId            String
  name                String
  funder              String
  description         String?
  fundingPurposes     String[]
  awardMin            Int?
  awardMax            Int?
  awardTypical        Int?
  eligibilityCriteria Json?
  geographicScope     String?
  deadline            DateTime?
  sourceUrl           String
  retrievedAt         DateTime
  status              GrantStatus
  detailsIncomplete   Boolean             @default(false)
  eligibilityResults  EligibilityResult[]
  shortlistItems      ShortlistItem[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@unique([groupId, sourceUrl])
}

enum GrantStatus {
  NEW
  UPDATED
  ACTIVE
  MAY_HAVE_CLOSED
  EXPIRED
}

model EligibilityResult {
  id                   String             @id @default(cuid())
  grantId              String
  grant                Grant              @relation(fields: [grantId], references: [id], onDelete: Cascade)
  groupId              String
  group                Group              @relation(fields: [groupId], references: [id], onDelete: Cascade)
  verdict              EligibilityVerdict
  criteriaResults      Json
  supplementaryAnswers Json?
  assessedAt           DateTime           @default(now())
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

enum EligibilityVerdict {
  LIKELY_ELIGIBLE
  PARTIAL
  LIKELY_INELIGIBLE
}

model ShortlistItem {
  id        String   @id @default(cuid())
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  grantId   String
  grant     Grant    @relation(fields: [grantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([groupId, grantId])
}
